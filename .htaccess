DirectoryIndex index.html

RewriteEngine On

# Remove the invalid SearchAction placeholder URL that was previously exposed to Google.
RewriteCond %{QUERY_STRING} (^|&)s=(%7B|\{)search_term_string(%7D|\})(?:&|$) [NC]
RewriteRule ^blog/?$ https://goflow.co.il/blog/ [R=301,L,NE,QSD]

# CRM service was renamed to reflect strategic consulting and specification.
RewriteRule ^services/crm-implementation/?$ https://goflow.co.il/services/crm-consulting/ [R=301,L,NE]

# Keep one canonical origin for search engines and shared links.
RewriteCond %{HTTPS} !=on [OR]
RewriteCond %{HTTP_HOST} ^www\.goflow\.co\.il$ [NC]
RewriteRule ^ https://goflow.co.il%{REQUEST_URI} [R=301,L,NE]

# Redirect explicit index files to their clean canonical directory URLs.
RewriteCond %{THE_REQUEST} \s/+(.*/)?index\.html(?:[\s?]) [NC]
RewriteRule ^(.*/)?index\.html$ https://goflow.co.il/$1 [R=301,L,NE]

# Missing files should return a real 404 instead of falling back to the home page.
ErrorDocument 404 /404.html

<IfModule mod_headers.c>
  Header always set Strict-Transport-Security "max-age=31536000"
  Header always set X-Content-Type-Options "nosniff"
  Header always set X-Frame-Options "SAMEORIGIN"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  Header always set Permissions-Policy "camera=(), microphone=(), geolocation=()"

  <FilesMatch "\.(html?)$">
    Header set Cache-Control "public, max-age=0, must-revalidate"
  </FilesMatch>

  <FilesMatch "\.(css|js)$">
    Header set Cache-Control "public, max-age=604800"
  </FilesMatch>

  <FilesMatch "\.(avif|gif|ico|jpe?g|png|svg|webp|woff2?)$">
    Header set Cache-Control "public, max-age=2592000"
  </FilesMatch>
</IfModule>
